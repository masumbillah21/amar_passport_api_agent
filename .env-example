# CrewAI runtime configuration for the API container.
# Set exactly one provider key, or leave multiple keys and the backend will
# prefer Groq first, then OpenAI, Anthropic, and Gemini.

CREWAI_DISABLE_TELEMETRY=true
OTEL_SDK_DISABLED=true
SHOW_AGENT_THINKING=false

GROQ_API_KEY=
GROQ_MODEL=groq/llama-3.3-70b-versatile

OPENAI_API_KEY=
OPENAI_MODEL_NAME=openai/gpt-4o-mini

ANTHROPIC_API_KEY=
ANTHROPIC_MODEL=anthropic/claude-3-5-sonnet-latest

GEMINI_API_KEY=
GEMINI_MODEL=gemini/gemini-2.0-flash
